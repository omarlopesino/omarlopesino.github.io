---
import Layout from './Layout.astro';

const { term } = Astro.props;

import { getContentAlternateUrls } from '@/lib/blog';
import type { Alternate } from '@/i18n/routes';
import PostTeaser from '@/components/ui/PostTeaser.astro';
import { getCollection } from 'astro:content';
import { getEntry } from 'astro:content';

const alternates : Alternate[] = await getContentAlternateUrls('blog', term.data);

const posts = await Promise.all((await getCollection('blog', (post) => post.data.language == term.data.language))
    .map(async (post) => {

        const tags = (await Promise.all(post.data.tags.map((tag) => getEntry('tag', tag.id + '/' + post.data.language)))).map((tag) => tag?.data);
        const category = (await getEntry('category', post.data.category.id + '/' + post.data.language))?.data;

        return {
            data: post.data,
            category: category,
            tags: tags,
        }
    }));

---

<Layout title={term.data.title} description={term.data.description} lang={term.data.language} alternates={alternates}>
    <h1>{term.data.title}</h1>
    <p class="text-sm">
        {term.data.description}
    </p>
    <div class="bg-gray-100 dark:bg-base-300 rounded-box max-w-full p-4">
        <h2 class="text-center font-bold text-lg mb-2">Related posts</h2>
        <div class:list={["md:flex md:justify-center space-x-4 p-2"]}>
            {
                posts.map((post) => (
                    <PostTeaser 
                        class:list="max-md:w-55 md:w-70"
                        title={post.data.title} 
                        description={post.data.description} 
                        category={post.category}
                        pubDate={post.data.pubDate}
                        image={post.data.image}
                        tags={post.tags}
                        url={post.data.url}
                    />
                ))
            }
        </div>
    </div>

</Layout>
