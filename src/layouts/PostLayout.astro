---
import Layout from './Layout.astro';
import Post from '../components/ui/Post.astro'

const { post, content } = Astro.props;

const Content = content;

import { getContentAlternateUrls, getPostCategory, getPostTags } from '@/lib/blog';
import type { Alternate } from '@/i18n/routes';

const tags = await getPostTags(post);
const category = await getPostCategory(post);
const alternates : Alternate[] = await getContentAlternateUrls('blog', post.data);

---

<Layout title={post.data.title} description={post.data.description} lang={post.data.language} alternates={alternates}>
	<Post 
        title={post.data.title} 
        description={post.data.description} 
        category={category}
        pubDate={post.data.pubDate}
        image={post.data.image}
        tags={tags}
        url={post.data.url}
    >
        <Content slot="content" />
    </Post>
</Layout>
