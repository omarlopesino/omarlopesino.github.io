---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import LanguageRedirect from '../components/LanguageRedirect.astro';

interface Props {
  title: string;
  description?: string;
  refresh?: string;
  languageRedirect?: boolean;
  lang?: string;
}

const { title, description, refresh, languageRedirect, lang } = Astro.props;
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    {description && <meta name="description" content={description} />}
    {refresh && <noscript><meta http-equiv="refresh" content={refresh} /></noscript>}
    {languageRedirect && <LanguageRedirect />}
    <title>{title}</title>
  </head>
  <body class="max-w-5xl mx-auto">
    <header class="lg:px-4">
      <Header />
    </header>
    <main class="my-6 px-6">
      <slot />
    </main>
    <footer class="lg:px-4">
      <Footer />
    </footer>
  </body>
</html>
