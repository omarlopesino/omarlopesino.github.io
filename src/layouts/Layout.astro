---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { defaultLang } from '../i18n/ui';
import type { Alternate } from '../i18n/routes';

interface Props {
  title: string;
  description?: string;
  refresh?: string;
  lang?: string;
  alternates?: Alternate[];
}

const { title, description, refresh, lang, alternates = [] } = Astro.props;

const origin = Astro.site?.origin ?? Astro.url.origin;
const self = alternates.find((a) => a.lang === lang);
const canonical = `${origin}${self ? self.path : Astro.url.pathname}`;
const xDefault = alternates.find((a) => a.lang === defaultLang);
---

<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <!-- @todo drop when the site is ready. -->
    <meta name="robots" content="noindex, nofollow">
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    {description && <meta name="description" content={description} />}
    {!refresh && <link rel="canonical" href={canonical} />}
    {alternates.map(({ lang: code, path }) => <link rel="alternate" hreflang={code} href={`${origin}${path}`} />)}
    {xDefault && <link rel="alternate" hreflang="x-default" href={`${origin}${xDefault.path}`} />}
    {refresh && <meta http-equiv="refresh" content={refresh} />}
    <title>{title}</title>
    <script is:inline>
      const theme = localStorage.getItem('theme');
      if (theme != null) {
        document.documentElement.setAttribute(
          'data-theme',
          localStorage.getItem('theme') ?? 'light'
        );
      }

      document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.querySelector('.theme-controller');
        if (!toggle) return;
        toggle.checked = (localStorage.getItem('theme') ?? 'light') === 'dark';
        toggle.addEventListener('change', (e) => {
          localStorage.setItem('theme', e.target.checked ? 'dark' : 'light');
        });
      });
    </script>
  </head>
  <body class="max-w-5xl mx-auto">
    <header class="lg:px-4">
      <Header alternates={alternates} />
    </header>
    <main class="my-6 px-6">
      <slot />
    </main>
    <footer class="lg:px-4">
      <Footer />
    </footer>
  </body>
</html>
