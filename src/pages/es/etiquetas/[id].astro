---

import { staticPaths } from '@/lib/blog';
import type { CollectionEntry } from 'astro:content';
import TermPostsLayout from '@/layouts/TermPostsLayout.astro';

interface Props {
  entry: CollectionEntry<'tag'>;
}

export const getStaticPaths = staticPaths('tag', 'es');

// 2. For your template, you can get the entry directly from the prop
const { entry } = Astro.props;
---

<TermPostsLayout term={entry} type="tag"/>
