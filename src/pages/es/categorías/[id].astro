---
import { staticPaths } from '@/lib/blog';
import type { CollectionEntry } from 'astro:content';
import TermsLayout from '@/layouts/TermsLayout.astro';

interface Props {
  entry: CollectionEntry<'category'>;
}

export const getStaticPaths = staticPaths('category', 'es');

// 2. For your template, you can get the entry directly from the prop
const { entry } = Astro.props;
---

<TermsLayout term={entry} type="category"/>
