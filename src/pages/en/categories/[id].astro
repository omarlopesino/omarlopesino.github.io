---

import { staticPaths } from '@/lib/blog';
import type { CollectionEntry } from 'astro:content';
import TermPostsLayout from '@/layouts/TermPostsLayout.astro';

interface Props {
  entry: CollectionEntry<'category'>;
}

export const getStaticPaths = staticPaths('category', 'en');

// 2. For your template, you can get the entry directly from the prop
const { entry } = Astro.props;
---

<TermPostsLayout term={entry} type="category"/>
