---
import Menu from './ui/Menu.astro';
import MenuLink from './ui/MenuLink.astro';
import Logo from './ui/Logo.astro';
import LanguageSwitcher from './ui/LanguageSwitcher.astro';
import { getLangFromUrl, useTranslations } from '../i18n/utils';
import type { Alternate } from '../i18n/routes';

const { alternates = [] } : { alternates?: Alternate[] } = Astro.props;

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

---
<Menu class="shadow-sm">
  <Logo slot="start" />
  <MenuLink href={"/" + lang + "/blog"}>{t('nav.blog')}</MenuLink>
  <MenuLink href={"/" + lang + "/about"}>{t('nav.about')}</MenuLink>
  <MenuLink href={"/" + lang + "/contact"} class="px-4 rounded-lg border border-current">{t('nav.contact')}</MenuLink>
  <li><LanguageSwitcher lang={lang} alternates={alternates} /></li>
</Menu>
