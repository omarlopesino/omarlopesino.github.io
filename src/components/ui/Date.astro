---
import { getLangFromUrl, useFormatDate } from '@/i18n/utils';

interface Props {
    date: string | Date,
    class?: string;
    [key: string]: unknown;
}

const lang = getLangFromUrl(Astro.url);
const formatDate = useFormatDate(lang);
const { class: className, date, ...rest } = Astro.props;
const isoDate = date instanceof Date ? date.toISOString() : date;

---
<time datetime={isoDate} class="text-sm" {...rest}>{formatDate(date)}</time>