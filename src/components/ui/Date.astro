---
import { getLangFromUrl, useFormatDate } from '@/i18n/utils';

interface Props {
    publishedDate: string,
    class?: string;
    [key: string]: unknown;
}

const lang = getLangFromUrl(Astro.url);
const formatDate = useFormatDate(lang);
const { class: className, publishedDate, ...rest } = Astro.props;

---
<time datetime={publishedDate} class="text-sm" {...rest}>{formatDate(publishedDate)}</time>