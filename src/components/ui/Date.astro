---
import { getLangFromUrl, useFormatDate } from '@/i18n/utils';

interface Props {
    date: string,
    class?: string;
    [key: string]: unknown;
}

const lang = getLangFromUrl(Astro.url);
const formatDate = useFormatDate(lang);
const { class: className, date, ...rest } = Astro.props;

---
<time datetime={date} class="text-sm" {...rest}>{formatDate(date)}</time>