---
import type { PostInterface } from '@/types'

import PostTeaser from './PostTeaser.astro';

interface Props {
    title: string;
    posts: PostInterface[],
    class?: string;
    [key: string]: unknown;
}

const { title, class: className, posts = [], ...rest } = Astro.props;

---

<div class="bg-gray-100 dark:bg-base-300 rounded-box max-w-full p-4">
    <h2 class="text-center font-bold text-lg mb-2">{title}</h2>
    <div class:list={[className, "md:flex md:justify-center carousel carousel-center space-x-4 p-2"]} {...rest}>
        {
            posts.map((post) => (
                <PostTeaser class="carousel-item max-md:w-55 md:w-70" {...post} />
            ))
        }
    </div>
</div>
