---
import { Icon } from 'astro-icon/components';
import type { Alternate } from '../../i18n/routes';

interface Props {
  lang: string; 
  alternates?: Alternate[]
}

const { lang, alternates = [] } = Astro.props;

const hrefFor = (code: string) => alternates.find((a) => a.lang === code)?.path ?? `/${code}/`;
const langs = ['en', 'es'];
---
<details class="dropdown dropdown-center">
  <summary class="btn btn-ghost btn-sm m-1 uppercase gap-1"><Icon class="w-4 h-4" name="mdi:translate" />{lang}</summary>
  <ul class="menu dropdown-content bg-base-100 rounded-box z-1 w-24 p-2 shadow-sm">
    {langs.map((code) => (
      <li>
        <a href={hrefFor(code)} class:list={[code === lang && 'font-bold', 'link link-hover uppercase justify-center text-center']}>{code}</a>
      </li>
    ))}
  </ul>
</details>
